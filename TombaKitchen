<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>North East & Manipuri Culinary Experience</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cloudflare.com">
    
    <style>
        /* Smooth transitions for theme switching */
        body, header, section, div, button, h1, h2, h3, p {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
        }
        
        /* Custom scrollbar for panels */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* Initial Traditional Earthy Palette Variables */
        :root {
            --color-primary: #9a3412; /* Terracotta */
            --color-secondary: #166534; /* Bamboo Green */
            --color-bg: #fdfbc9; /* Warm Cream */
            --color-text: #1e293b;
            --font-main: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="bg-[#fdfcfa] text-slate-800 font-['Inter'] antialiased">

    <!-- =========================================================================
         ADMIN SIDEBAR PANEL (Visual Customizer & Menu Management)
         ========================================================================= -->
    <div id="adminPanel" class="fixed top-0 left-0 h-full w-80 bg-slate-900 text-slate-100 z-50 shadow-2xl transform translate-x-0 transition-transform duration-300 flex flex-col border-r border-slate-700">
        <!-- Header -->
        <div class="p-4 bg-slate-950 flex justify-between items-center border-b border-slate-800">
            <h2 class="text-lg font-bold tracking-wide text-amber-500"><i class="fa-solid testimonies fa-sliders mr-2"></i>Live Admin Editor</h2>
            <button onclick="toggleAdminPanel()" class="text-slate-400 hover:text-white p-1">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <!-- Scrollable Controls -->
        <div class="flex-1 overflow-y-auto p-4 space-y-6">
            
            <!-- Section 1: Hero & Logo Customizer -->
            <div class="space-y-3 bg-slate-800/50 p-3 rounded-lg border border-slate-700">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400"><i class="fa-solid fa-heading mr-1"></i> Identity & Hero</h3>
                <div>
                    <label class="block text-xs font-medium text-slate-300 mb-1">Restaurant Name</label>
                    
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-300 mb-1">Logo Text Size (px)</label>
                    
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-300 mb-1">Logo Text Color</label>
                    
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-300 mb-1">Hero Image URL</label>
                    
                </div>
            </div>

            <!-- Section 2: Global Theme Presets -->
            <div class="space-y-3 bg-slate-800/50 p-3 rounded-lg border border-slate-700">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400"><i class="fa-solid fa-palette mr-1"></i> Styling & Themes</h3>
                <div>
                    <label class="block text-xs font-medium text-slate-300 mb-1">Color Scheme</label>
                    <select id="selectTheme" onchange="changeThemePreset()" class="w-full bg-slate-700 text-white text-sm rounded px-2 py-1.5 focus:outline-none focus:ring-1 focus:ring-amber-500">
                        <option value="earthy">Traditional Earthy</option>
                        <option value="minimal">Modern Minimalist</option>
                        <option value="dark">Dark Elegant</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-300 mb-1">Global Typography</label>
                    <select id="selectFont" onchange="changeFontFamily()" class="w-full bg-slate-700 text-white text-sm rounded px-2 py-1.5 focus:outline-none focus:ring-1 focus:ring-amber-500">
                        <option value="sans">Modern Sans-Serif</option>
                        <option value="serif">Elegant Serif</option>
                    </select>
                </div>
            </div>

            <!-- Section 3: Add New Menu Item -->
            <div class="space-y-3 bg-slate-800/50 p-3 rounded-lg border border-slate-700">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400"><i class="fa-solid fa-plus mr-1"></i> Add Menu Item</h3>
                <div>
                    <label class="block text-xs font-medium text-slate-300 mb-1">Item Name</label>
                    <input type="text" id="menuItemName" placeholder="e.g., Fish Thali" class="w-full bg-slate-700 text-white text-sm rounded px-2 py-1.5 focus:outline-none">
                </div>
                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-xs font-medium text-slate-300 mb-1">Price (₹)</label>
                        <input type="number" id="menuItemPrice" placeholder="250" class="w-full bg-slate-700 text-white text-sm rounded px-2 py-1.5 focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-300 mb-1">Category</label>
                        <select id="menuItemCategory" class="w-full bg-slate-700 text-white text-sm rounded px-2 py-1.5 focus:outline-none">
                            <option value="starters">Starters</option>
                            <option value="manipuri">Manipuri Main</option>
                            <option value="northeast">NE Specialties</option>
                            <option value="beverages">Beverages</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-300 mb-1">Description</label>
                    <textarea id="menuItemDesc" rows="2" placeholder="Brief description of flavours..." class="w-full bg-slate-700 text-white text-sm rounded px-2 py-1.5 focus:outline-none"></textarea>
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-300 mb-1">Image URL</label>
                    <input type="text" id="menuItemImg" placeholder="https://unsplash.com..." class="w-full bg-slate-700 text-white text-sm rounded px-2 py-1.5 focus:outline-none">
                </div>
                <button onclick="addMenuItem()" class="w-full bg-amber-600 hover:bg-amber-500 text-white text-sm font-semibold py-2 rounded shadow transition">Add to Menu Grid</button>
            </div>

        </div>
        <!-- Footer Info -->
        <div class="p-3 bg-slate-950 text-center text-[11px] text-slate-500 border-t border-slate-800">
            Client view updates dynamically.
        </div>
    </div>

    <!-- Toggle Admin Panel Button -->
    <button id="toggleAdminBtn" onclick="toggleAdminPanel()" class="fixed bottom-6 right-6 z-50 bg-slate-900 hover:bg-slate-800 text-amber-500 shadow-2xl p-4 rounded-full border border-slate-700 transform hover:scale-110 transition flex items-center justify-center">
        <i id="toggleAdminIcon" class="fa-solid fa-gear text-2xl animate-spin-slow"></i>
    </button>


    <!-- =========================================================================
         PUBLIC RESTAURANT PAGE VIEW
         ========================================================================= -->
    <div id="pageWrapper" class="min-h-screen flex flex-col bg-[#fdfbe9] text-stone-900">
        
        <!-- Header / Navigation -->
        <header id="mainHeader" class="bg-white/90 backdrop-blur-md shadow-sm sticky top-0 z-40 transition-colors">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex justify-between items-center">
                <!-- Live Logo and Title Container -->
                <div class="flex items-center space-x-3">
                    <div id="logoIconContainer" class="h-10 w-10 rounded-full flex items-center justify-center bg-orange-700 text-white">
                        <i class="fa-solid fa-utensils"></i>
                    </div>
                    <span id="displayRestName" class="font-bold tracking-tight text-orange-800" style="font-size: 24px; color: #9a3412;">The Bamboo Shoot</span>
                </div>

                <!-- Navigation Links -->
                <nav class="hidden md:flex space-x-8 text-sm font-medium">
                    <a href="#hero" class="hover:text-orange-700 transition">Home</a>
                    <a href="#menu" class="hover:text-orange-700 transition">Menu Grid</a>
                    <a href="#about" class="hover:text-orange-700 transition">Our Heritage</a>
                    <a href="#contact" class="hover:text-orange-700 transition">Contact Us</a>
                </nav>

                <!-- Mobile Menu Button -->
                <div class="md:hidden">
                    <button class="p-2 text-stone-600 hover:text-stone-900"><i class="fa-solid fa-bars text-xl"></i></button>
                </div>
            </div>
        </header>

        <!-- Hero Section -->
        <section id="hero" class="relative min-h-[550px] flex items-center justify-center bg-cover bg-center transition-all duration-500" style="background-image: linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.65)), url('https://unsplash.comphoto-1606787366850-de6330128bfc?auto=format&fit=crop&w=1600&q=80');">
            <div class="text-center px-4 max-w-3xl mx-auto space-y-6">
                <span class="inline-block uppercase tracking-widest text-xs font-semibold bg-amber-500 text-slate-900 px-3 py-1 rounded-full">Authentic Culinary Passage</span>
                <h1 id="heroTitle" class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-white tracking-tight">The Bamboo Shoot</h1>
                <p id="heroTagline" class="text-lg sm:text-xl text-stone-200 font-light max-w-xl mx-auto">
                    Taste the Authentic Flavors of the Hills, traditional North East and indigenous Manipuri delicacies.
                </p>
                <div class="pt-4">
                    <a href="#menu" class="inline-block bg-orange-700 hover:bg-orange-600 text-white font-semibold px-8 py-3 rounded-md shadow-lg transition transform hover:-translate-y-0.5">Explore Live Menu</a>
                </div>
            </div>
            <!-- Decorative wave edge -->
            <div class="absolute bottom-0 left-0 right-0 h-8 bg-transparent"></div>
        </section>

        <!-- Menu Section -->
        <section id="menu" class="py-16 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto w-full flex-1">
            <div class="text-center max-w-xl mx-auto mb-12 space-y-2">
                <h2 class="text-3xl font-bold tracking-tight border-b-2 border-orange-700/20 inline-block pb-2">Our Culinary Offerings</h2>
                <p class="text-stone-500 text-sm">Fresh ingredients, authentic spices, and time-honoured heritage recipes cooked with precision.</p>
            </div>

            <!-- Categories Tabs -->
            <div class="flex flex-wrap justify-center gap-2 mb-10">
                <button onclick="filterCategory('all')" class="menu-tab-btn active px-4 py-2 text-xs uppercase tracking-wider font-bold rounded-full bg-orange-800 text-white shadow-sm transition">All Dishes</button>
                <button onclick="filterCategory('starters')" class="menu-tab-btn px-4 py-2 text-xs uppercase tracking-wider font-bold rounded-full bg-white text-stone-600 hover:bg-stone-100 transition shadow-sm">Starters</button>
                <button onclick="filterCategory('manipuri')" class="menu-tab-btn px-4 py-2 text-xs uppercase tracking-wider font-bold rounded-full bg-white text-stone-600 hover:bg-stone-100 transition shadow-sm">Manipuri Main</button>
                <button onclick="filterCategory('northeast')" class="menu-tab-btn px-4 py-2 text-xs uppercase tracking-wider font-bold rounded-full bg-white text-stone-600 hover:bg-stone-100 transition shadow-sm">NE Specialties</button>
                <button onclick="filterCategory('beverages')" class="menu-tab-btn px-4 py-2 text-xs uppercase tracking-wider font-bold rounded-full bg-white text-stone-600 hover:bg-stone-100 transition shadow-sm">Beverages</button>
            </div>

            <!-- Menu Items Grid Container -->
            <div id="menuGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Dynamically Inserted Cards -->
            </div>
        </section>

        <!-- About / Heritage Section -->
        <section id="about" class="bg-stone-100 py-16 px-4 sm:px-6 lg:px-8 border-t border-stone-200">
            <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="space-y-6">
                    <span class="text-xs uppercase font-bold tracking-widest text-emerald-700 block">Our Roots</span>
                    <h2 class="text-3xl font-bold tracking-tight text-stone-900">The Heritage of North East & Manipuri Flavours</h2>
                    <p class="text-stone-600 leading-relaxed text-sm">
                        Our kitchen honors the rich tapestry of flavors coming directly from northeastern hills and lowlands. From the clean, aromatic profile of traditional Manipuri preparations to the deep, complex notes of slow-smoked specialties, we bring authentic traditional dining profiles onto your plate.
                    </p>
                    <p class="text-stone-600 leading-relaxed text-sm">
                        Using locally sourced bamboo shoots, ghost peppers (Raja Mircha), indigenous herbs, and traditional fermentation crafts, each plate shares a unique cultural chronicle.
                    </p>
                    <div class="grid grid-cols-3 gap-4 text-center pt-4">
                        <div class="p-3 bg-white rounded-lg shadow-sm"><p class="text-2xl font-bold text-orange-800">100%</p><p class="text-[11px] text-stone-500 uppercase font-medium">Authentic</p></div>
                        <div class="p-3 bg-white rounded-lg shadow-sm"><p class="text-2xl font-bold text-emerald-800">Fresh</p><p class="text-[11px] text-stone-500 uppercase font-medium">Ingredients</p></div>
                        <div class="p-3 bg-white rounded-lg shadow-sm"><p class="text-2xl font-bold text-amber-800">Traditional</p><p class="text-[11px] text-stone-500 uppercase font-medium">Chefs</p></div>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <img src="https://unsplash.comphoto-1546069901-ba9599a7e63c?auto=format&fit=crop&w=600&q=80" alt="Fresh ingredients" class="rounded-xl shadow-md h-48 w-full object-cover">
                    <img src="https://unsplash.comphoto-1512621776951-a57141f2eefd?auto=format&fit=crop&w=600&q=80" alt="Healthy plating" class="rounded-xl shadow-md h-48 w-full object-cover mt-6">
                </div>
            </div>
        </section>

        <!-- Footer / Contact Info -->
        <footer id="contact" class="bg-stone-900 text-stone-300 py-12 px-4 sm:px-6 lg:px-8 border-t border-stone-800">
            <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 text-sm">
                <div class="space-y-3">
                    <h3 class="text-white text-base font-bold tracking-wide">The Bamboo Shoot</h3>
                    <p class="text-stone-400 text-xs">Bringing the culinary magic and rare herbal ingredients of the North East frontiers directly to your sensory landscape.</p>
                </div>
                <div class="space-y-2">
                    <h4 class="text-white font-semibold">Hours of Operation</h4>
                    <p class="text-xs text-stone-400">Tuesday – Sunday: 11:30 AM – 10:30 PM</p>
                    <p class="text-xs text-stone-500">Closed on Mondays</p>
                </div>
                <div class="space-y-2">
                    <h4 class="text-white font-semibold">Contact & Address</h4>
                    <p class="text-xs text-stone-400"><i class="fa-solid fa-location-dot mr-2 text-amber-500"></i> 12/4 Heritage Arcade, Seven Sisters Lane, Hub City</p>
                    <p class="text-xs text-stone-400"><i class="fa-solid fa-phone mr-2 text-amber-500"></i> +91 98765 43210</p>
                    <p class="text-xs text-stone-400"><i class="fa-solid fa-envelope mr-2 text-amber-500"></i> dine@bambooshoot.com</p>
                </div>
            </div>
            <div class="max-w-7xl mx-auto mt-8 pt-6 border-t border-stone-800 text-center text-xs text-stone-500">
                &copy; 2026 The Bamboo Shoot Restaurant. All rights reserved.
            </div>
        </footer>

    </div>

    <!-- =========================================================================
         CORE JAVASCRIPT STATE MANAGEMENT & HANDLERS
         ========================================================================= -->
    <script>
        // Initial Mock Database for Menu Items
        let menuItems = [
            {
                id: 1,
                name: "Manipuri Eromba",
                price: 180,
                category: "manipuri",
                description: "An authentic, healthy Manipuri favorite made of boiled vegetables, mashed together with roasted red chillies and fermented fish (Ngari), topped with fresh coriander.",
                img: "https://unsplash.comphoto-1546069901-ba9599a7e63c?auto=format&fit=crop&w=500&q=80"
            },
            {
                id: 2,
                name: "Smoked Pork with Bamboo Shoot",
                price: 360,
                category: "northeast",
                description: "Slow-cooked authentic wood-smoked pork infused with local fermented bamboo shoots, spicy ghost pepper flakes, and regional herbs.",
                img: "https://unsplash.comphoto-1603360946369-dc9bb6258143?auto=format&fit=crop&w=500&q=80"
            },
            {
                id: 3,
                name: "Singju",
                price: 120,
                category: "starters",
                description: "A fiery and crisp traditional Manipuri salad featuring finely shredded cabbage, seasonal greens, lotus root, dressed in an aromatic roasted perilla seed paste mix.",
                img: "https://unsplash.comphoto-1512621776951-a57141f2eefd?auto=format&fit=crop&w=500&q=80"
            }
        ];

        let currentFilter = 'all';

        // Toggle Sidebar visibility
        function toggleAdminPanel() {
            const panel = document.getElementById('adminPanel');
            const icon = document.getElementById('toggleAdminIcon');
            panel.classList.toggle('-translate-x-0');
            panel.classList.toggle('-translate-x-full');
        }

        // Live update Identity settings (Restaurant name, logo size/color, hero)
        function updateIdentity() {
            const nameVal = document.getElementById('inputRestName').value;
            const sizeVal = document.getElementById('inputLogoSize').value;
            const colorVal = document.getElementById('inputLogoColor').value;
            const heroBg = document.getElementById('inputHeroBg').value;

            // Apply to Header layout
            document.getElementById('displayRestName').innerText = nameVal;
            document.getElementById('displayRestName').style.fontSize = `${sizeVal}px`;
            document.getElementById('displayRestName').style.color = colorVal;
            document.getElementById('logoIconContainer').style.backgroundColor = colorVal;

            // Apply to Hero elements
            document.getElementById('heroTitle').innerText = nameVal;
            document.getElementById('hero').style.backgroundImage = `linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.65)), url('${heroBg}')`;
        }

        // Apply global style preset changes
        function changeThemePreset() {
            const scheme = document.getElementById('selectTheme').value;
            const pageWrapper = document.getElementById('pageWrapper');
            const mainHeader = document.getElementById('mainHeader');
            const aboutSec = document.getElementById('about');

            if (scheme === 'earthy') {
                pageWrapper.className = "min-h-screen flex flex-col bg-[#fdfbe9] text-stone-900";
                mainHeader.className = "bg-white/90 backdrop-blur-md shadow-sm sticky top-0 z-40";
                aboutSec.className = "bg-stone-100 py-16 px-4 sm:px-6 lg:px-8 border-t border-stone-200";
            } else if (scheme === 'minimal') {
                pageWrapper.className = "min-h-screen flex flex-col bg-white text-zinc-900";
                mainHeader.className = "bg-zinc-50 border-b border-zinc-200 sticky top-0 z-40";
                aboutSec.className = "bg-zinc-50 py-16 px-4 sm:px-6 lg:px-8 border-t border-zinc-200";
            } else if (scheme === 'dark') {
                pageWrapper.className = "min-h-screen flex flex-col bg-zinc-950 text-zinc-100";
                mainHeader.className = "bg-zinc-900/95 border-b border-zinc-800 sticky top-0 z-40 text-white";
                aboutSec.className = "bg-zinc-900 py-16 px-4 sm:px-6 lg:px-8 border-t border-zinc-800";
            }
            renderMenu();
        }

        // Change global typography font families
        function changeFontFamily() {
            const font = document.getElementById('selectFont').value;
            if (font === 'serif') {
                document.body.style.fontFamily = "'Playfair Display', serif";
            } else {
                document.body.style.fontFamily = "'Inter', sans-serif";
            }
        }

        // Handle Active filter tab UI
        function filterCategory(cat) {
            currentFilter = cat;
            const tabs = document.querySelectorAll('.menu-tab-btn');
            tabs.forEach(tab => {
                tab.classList.remove('bg-orange-800', 'text-white');
                tab.classList.add('bg-white', 'text-stone-600');
            });

            // Find clicked button to set active state classes
            event.currentTarget.classList.remove('bg-white', 'text-stone-600');
            event.currentTarget.classList.add('bg-orange-800', 'text-white');

            renderMenu();
        }

        // Add menu item to array
        function addMenuItem() {
            const name = document.getElementById('menuItemName').value.trim();
            const price = parseFloat(document.getElementById('menuItemPrice').value) || 0;
            const category = document.getElementById('menuItemCategory').value;
            const description = document.getElementById('menuItemDesc').value.trim();
            let img = document.getElementById('menuItemImg').value.trim();

            if(!name || !description) {
                alert('Please provide at least an item name and details description.');
                return;
            }

            if(!img) {
                img = 'https://unsplash.comphoto-1546069901-ba9599a7e63c?auto=format&fit=crop&w=500&q=80'; // fallback
            }

            const newItem = {
                id: Date.now(),
                name,
                price,
                category,
                description,
                img
            };

            menuItems.push(newItem);
            renderMenu();

            // Clear Input Fields
            document.getElementById('menuItemName').value = '';
            document.getElementById('menuItemPrice').value = '';
            document.getElementById('menuItemDesc').value = '';
            document.getElementById('menuItemImg').value = '';
        }

        // Delete menu item operation
        function deleteItem(id) {
            menuItems = menuItems.filter(item => item.id !== id);
            renderMenu();
        }

        // Render function mapping data arrays into visual markup cards
        function renderMenu() {
            const grid = document.getElementById('menuGrid');
            grid.innerHTML = '';

            const currentScheme = document.getElementById('selectTheme').value;
            const cardBgClass = currentScheme === 'dark' ? 'bg-zinc-900 border-zinc-800 text-white' : 'bg-white border-stone-100 text-stone-900';
            const textMutedClass = currentScheme === 'dark' ? 'text-zinc-400' : 'text-stone-500';

            const filtered = menuItems.filter(item => currentFilter === 'all' || item.category === currentFilter);

            if(filtered.length === 0) {
                grid.innerHTML = `
                    <div class="col-span-full text-center py-12 text-stone-400">
                        <i class="fa-regular fa-folder-open text-4xl mb-2 block"></i>
                        No menu items present under this segment category. Add items using the configuration workspace.
                    </div>
                `;
                return;
            }

            filtered.forEach(item => {
                const card = document.createElement('div');
                card.className = `${cardBgClass} rounded-xl overflow-hidden shadow-sm hover:shadow-md border transition duration-200 relative group flex flex-col`;
                
                card.innerHTML = `
                    <div class="relative h-48 w-full bg-stone-200 overflow-hidden">
                        <img src="${item.img}" alt="${item.name}" class="h-full w-full object-cover group-hover:scale-105 transition duration-300">
                        <!-- Admin Control Flag visible on hover or default focus inside card -->
                        <button onclick="deleteItem(${item.id})" class="absolute top-3 right-3 bg-red-600 hover:bg-red-700 text-white text-xs h-7 w-7 rounded-full flex items-center justify-center shadow opacity-90 transition" title="Remove Item From Live Deployment">
                            <i class="fa-solid fa-trash-can"></i>
                        </button>
                        <span class="absolute bottom-3 left-3 bg-black/60 text-amber-400 font-bold px-2 py-0.5 rounded text-xs tracking-wider">
                            ${item.category.toUpperCase()}       
                        </span>
                    </div>
                    <div class="p-5 flex-1 flex flex-col justify-between space-y-3">
                        <div>
                            <div class="flex justify-between items-start">
                                <h3 class="font-bold text-lg tracking-tight">${item.name}</h3>
                                <span class="text-orange-700 dark:text-amber-400 font-extrabold text-base ml-2">₹${item.price}</span>
                            </div>
                            <p class="${textMutedClass} text-xs mt-2 leading-relaxed line-clamp-3">${item.description}</p>
                        </div>
                        <div class="pt-2 border-t border-dashed border-stone-200/60 flex items-center justify-between">
                            <span class="text-[11px] text-stone-400">Chef Special Pick</span>
                            <button class="text-xs font-semibold text-orange-700 dark:text-amber-400 flex items-center gap-1 hover:underline">Order Preview <i class="fa-solid fa-arrow-right text-[10px]"></i></button>
                        </div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        // Run component compilation on initial template configuration load
        window.onload = function() {
            renderMenu();
            updateIdentity();
        };
    </script>
</body>
